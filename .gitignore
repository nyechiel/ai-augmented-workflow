meetings/
triages/
reviews/
quarterly-reviews/
stakeholders/*
!stakeholders/README.md
presentations/

# IDE
.vscode/
.idea/

# Claude Code plans and handoff (session-specific)
.claude/plans/
.claude/HANDOFF.md

# App Dashboard local config and logs
app-dashboard/apps.json
app-dashboard/logs/

# OS files
.DS_Store
Thumbs.db
