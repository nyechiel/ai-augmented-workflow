# AI-Augmented Workflow - MCP Secrets
# Copy this file to mcp-secrets.env and fill in your values.
# NEVER commit mcp-secrets.env to git.

# --- Google OAuth ---
# 1. Create a GCP project and enable: Gmail, Calendar, Drive, Docs, Sheets, Slides, People APIs
# 2. Configure OAuth consent screen (External or Internal)
# 3. Create an OAuth 2.0 Client ID (Desktop application)
# 4. Use the GWS MCP server's auth flow or Google OAuth Playground to get a refresh token
# Guide: https://github.com/nyechiel/google_workspace_mcp#authentication
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REFRESH_TOKEN=your-refresh-token
USER_GOOGLE_EMAIL=you@company.com

# --- Slack ---
# Browser session tokens (not bot tokens). Extract from browser dev tools.
# See: https://github.com/nyechiel/slack-mcp-server#authentication
SLACK_MCP_XOXC_TOKEN=xoxc-your-token
SLACK_MCP_XOXD_TOKEN=xoxd-your-token
SLACK_MCP_USER_AGENT=Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36
SLACK_MCP_CUSTOM_TLS=1

# --- Timezone ---
# IANA timezone for the time server (e.g., America/New_York, Europe/London, Asia/Tokyo)
TZ=UTC
